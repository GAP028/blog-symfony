{% extends 'base.html.twig' %}

{% block title %}Accueil du Royaume{% endblock %}

{% block body %}
    <div class="container">
        <div class="hero-panel text-center mb-5">
            <div class="hero-kicker">Portfolio — Univers Fantasy</div>
            <h1 class="hero-title">Les Chroniques du Royaume</h1>
            <p class="hero-subtitle">
                Un blog immersif inspiré d’un univers médiéval-fantastique, développé avec Symfony, Bootstrap et une gestion complète des rôles, des articles, des maisons et des commentaires.
            </p>

            {% if app.user %}
                <div class="alert alert-success d-inline-block px-4 py-3 mb-4">
                    Vous êtes connecté en tant que <strong>{{ app.user.email }}</strong>
                </div>

                <div>
                    <a href="{{ path('post_list') }}" class="btn btn-gold btn-lg me-2">Entrer dans les chroniques</a>
                    <a href="{{ path('app_logout') }}" class="btn btn-outline-gold btn-lg">Quitter la cour</a>
                </div>
            {% else %}
                <div>
                    <a href="{{ path('app_login') }}" class="btn btn-gold btn-lg me-2">Se connecter</a>
                    <a href="{{ path('app_register') }}" class="btn btn-outline-gold btn-lg">Créer un compte</a>
                </div>
            {% endif %}
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="gothic-card p-4 h-100">
                    <h3 class="section-title">Les Chroniques</h3>
                    <p class="soft-text">
                        Explorez les récits du royaume, les intrigues politiques, les alliances et les batailles.
                    </p>
                    <div class="quote-box mb-3">
                        “Chaque chronique est une trace laissée dans l’histoire du royaume.”
                    </div>
                    <a href="{{ path('post_list') }}" class="btn btn-gold">Voir les chroniques</a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="gothic-card p-4 h-100">
                    <h3 class="section-title">Les Grandes Maisons</h3>
                    <p class="soft-text">
                        Découvrez les maisons majeures, leurs valeurs, leur prestige et leurs ambitions.
                    </p>
                    <div class="quote-box mb-3">
                        “Les maisons façonnent le destin des royaumes.”
                    </div>
                    <a href="{{ path('category_list') }}" class="btn btn-outline-gold">Voir les maisons</a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="gothic-card p-4 h-100">
                    <h3 class="section-title">L’Héritage du Développeur</h3>
                    <p class="soft-text">
                        Ce projet a été conçu comme une démonstration de compétences Symfony à destination des recruteurs.
                    </p>
                    <div class="quote-box">
                        Créé et structuré par <strong class="text-gold">Gomas Alain-Patrick</strong>.
                    </div>
                </div>
            </div>
        </div>

        <div class="gothic-card p-4 mt-4">
            <h3 class="section-title">Guide des rôles et fonctionnalités</h3>
            <p class="soft-text mb-4">
                Cette section permet aux recruteurs et aux évaluateurs de comprendre rapidement les différents niveaux d’accès disponibles dans l’application ainsi que les fonctionnalités associées à chaque rôle.
            </p>

            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="gothic-card p-4 h-100">
                        <h4 class="text-gold mb-3">Visiteur</h4>
                        <p class="soft-text">
                            Le visiteur est un utilisateur non connecté. Il peut consulter librement le contenu public du site.
                        </p>
                        <ul class="soft-text mb-0">
                            <li>Voir la page d’accueil</li>
                            <li>Consulter les chroniques</li>
                            <li>Consulter les maisons / catégories</li>
                            <li>Voir le détail d’un article</li>
                            <li>Voir les commentaires validés</li>
                            <li>Accéder aux pages de connexion et d’inscription</li>
                        </ul>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="gothic-card p-4 h-100">
                        <h4 class="text-gold mb-3">Utilisateur connecté</h4>
                        <p class="soft-text">
                            L’utilisateur connecté possède un compte standard et peut interagir davantage avec l’application.
                        </p>
                        <ul class="soft-text mb-0">
                            <li>Se connecter / se déconnecter</li>
                            <li>Consulter son profil</li>
                            <li>Ajouter des commentaires</li>
                            <li>Voir sa photo de profil</li>
                            <li>Participer au contenu du site selon les permissions définies</li>
                        </ul>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="gothic-card p-4 h-100">
                        <h4 class="text-gold mb-3">Administrateur</h4>
                        <p class="soft-text">
                            L’administrateur dispose d’un accès complet à la gestion du blog et à la modération.
                        </p>
                        <ul class="soft-text mb-0">
                            <li>Créer, modifier et supprimer des chroniques</li>
                            <li>Créer, modifier et supprimer des catégories</li>
                            <li>Ajouter, modifier et supprimer des utilisateurs</li>
                            <li>Changer les rôles des utilisateurs</li>
                            <li>Activer ou désactiver des comptes</li>
                            <li>Valider, refuser ou supprimer des commentaires</li>
                            <li>Accéder au journal des actions administrateur</li>
                            <li>Uploader des images ou utiliser des liens d’images</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="gothic-card p-4 mt-4">
                <h3 class="section-title">Salle du Conseil</h3>
                <p class="soft-text">
                    En tant qu’administrateur, vous gouvernez les chroniques du royaume, les maisons nobles, les utilisateurs et les commentaires.
                </p>
                <div class="d-flex gap-2 flex-wrap">
                    <a href="{{ path('post_new') }}" class="btn btn-gold">Nouvelle chronique</a>
                    <a href="{{ path('category_new') }}" class="btn btn-dark-red">Nouvelle maison</a>
                    <a href="{{ path('admin_user_list') }}" class="btn btn-outline-gold">Gérer les utilisateurs</a>
                    <a href="{{ path('admin_comment_list') }}" class="btn btn-outline-gold">Modérer les commentaires</a>
                    <a href="{{ path('admin_log_list') }}" class="btn btn-outline-gold">Voir le journal admin</a>
                </div>
            </div>
        {% endif %}

        <div class="text-center mt-5">
            <p class="meta-text mb-1">Projet imaginé, structuré et réalisé par</p>
            <h4 class="text-gold mb-0">Gomas Alain-Patrick</h4>
        </div>

        <div class="gothic-card p-4 mt-4">
            <h3 class="section-title">À propos du projet</h3>
            <p class="soft-text mb-3">
                Ce projet est un blog immersif développé avec Symfony et Bootstrap, pensé comme démonstration technique à destination des recruteurs.
            </p>

            <ul class="soft-text mb-3">
                <li>Authentification complète : inscription, connexion, déconnexion</li>
                <li>Gestion des rôles : administrateur, utilisateur connecté, visiteur</li>
                <li>Gestion des chroniques, maisons/catégories et commentaires</li>
                <li>Espace d’administration pour gérer les utilisateurs et modérer les commentaires</li>
                <li>Journal des actions administrateur pour la traçabilité</li>
                <li>Upload d’images ou utilisation de liens d’images</li>
                <li>Interface personnalisée inspirée d’un univers médiéval-fantastique</li>
            </ul>

            <div class="alert alert-warning">
                <strong>Compte admin de démonstration :</strong><br>
                Email : admin@gomas-portfolio.com<br>
                Mot de passe : Admin1234
            </div>
        </div>
    </div>
{% endblock %}