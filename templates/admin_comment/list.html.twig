{% extends 'base.html.twig' %}

{% block title %}Gestion des commentaires{% endblock %}

{% block body %}
    <div class="container">
        <div class="gothic-card p-4">
            <div class="brand-mark">Administration</div>
            <h1 class="section-title mb-2">Gestion des commentaires</h1>
            <p class="soft-text">Approuvez, refusez ou supprimez les commentaires du royaume.</p>

            {% if comments is empty %}
                <div class="alert alert-info mt-4">Aucun commentaire enregistré.</div>
            {% else %}
                <div class="table-responsive mt-4">
                    <table class="table table-dark table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Contenu</th>
                                <th>Auteur</th>
                                <th>Article</th>
                                <th>Statut</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for comment in comments %}
                                <tr>
                                    <td>{{ comment.id }}</td>
                                    <td>{{ comment.content|slice(0, 80) }}{% if comment.content|length > 80 %}...{% endif %}</td>
                                    <td>{{ comment.author ? comment.author.email : 'Inconnu' }}</td>
                                    <td>{{ comment.post ? comment.post.title : 'Aucun' }}</td>
                                    <td>{{ comment.status ?: 'non défini' }}</td>
                                    <td>{{ comment.createdAt ? comment.createdAt|date('d/m/Y H:i') : '' }}</td>
                                    <td class="d-flex gap-1 flex-wrap">
                                        <a href="{{ path('admin_comment_approve', {'id': comment.id}) }}" class="btn btn-sm btn-gold">Valider</a>
                                        <a href="{{ path('admin_comment_reject', {'id': comment.id}) }}" class="btn btn-sm btn-dark-red">Refuser</a>

                                        <form method="post" action="{{ path('admin_comment_delete', {'id': comment.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer ce commentaire ?');">
                                            <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}