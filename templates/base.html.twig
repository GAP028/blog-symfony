<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Chroniques du Royaume{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">

        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
            <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:wght@400;500;600&display=swap" rel="stylesheet">

            <style>
                :root {
                    --bg-main: #0d0b10;
                    --bg-secondary: #15121a;
                    --bg-card: rgba(24, 20, 28, 0.92);
                    --gold: #c9a96a;
                    --gold-soft: #e0c58d;
                    --text-main: #f3eee4;
                    --text-soft: #cfc6b8;
                    --border: rgba(201, 169, 106, 0.35);
                    --danger-dark: #6c1f1f;
                }

                body {
                    background:
                        linear-gradient(rgba(7, 7, 10, 0.86), rgba(7, 7, 10, 0.94)),
                        url('https://images.unsplash.com/photo-1518562180175-34a163b1a9a6?auto=format&fit=crop&w=1600&q=80') center/cover fixed no-repeat;
                    color: var(--text-main);
                    font-family: 'Cormorant Garamond', serif;
                    min-height: 100vh;
                }

                h1, h2, h3, h4, h5, .navbar-brand, .section-title, .btn {
                    font-family: 'Cinzel', serif;
                    letter-spacing: 0.4px;
                }

                .navbar {
                    background: rgba(10, 8, 14, 0.92) !important;
                    backdrop-filter: blur(6px);
                    border-bottom: 1px solid var(--border);
                }

                .navbar-brand {
                    color: var(--gold-soft) !important;
                    font-size: 1.25rem;
                    font-weight: 700;
                }

                .nav-link {
                    color: var(--text-soft) !important;
                    transition: 0.25s ease;
                }

                .nav-link:hover {
                    color: var(--gold-soft) !important;
                }

                .gothic-hero {
                    background:
                        linear-gradient(135deg, rgba(18, 14, 22, 0.95), rgba(41, 27, 18, 0.88));
                    border: 1px solid var(--border);
                    border-radius: 24px;
                    padding: 3.5rem 2rem;
                    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.45);
                    margin-bottom: 2rem;
                    position: relative;
                    overflow: hidden;
                }

                .gothic-hero::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: radial-gradient(circle at top right, rgba(201,169,106,0.12), transparent 35%);
                    pointer-events: none;
                }

                .gothic-card {
                    background: var(--bg-card);
                    border: 1px solid var(--border);
                    border-radius: 22px;
                    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.35);
                    color: var(--text-main);
                }

                .section-title {
                    color: var(--gold-soft);
                    font-weight: 700;
                }

                .text-gold {
                    color: var(--gold-soft);
                }

                .btn-gold {
                    background: linear-gradient(135deg, #9f7b3f, #d6b47a);
                    border: none;
                    color: #1a1410;
                    font-weight: 700;
                }

                .btn-gold:hover {
                    background: linear-gradient(135deg, #b8904d, #ebca8f);
                    color: #120e0c;
                }

                .btn-dark-red {
                    background: linear-gradient(135deg, #4b1111, #7a2323);
                    border: none;
                    color: #fff3e6;
                }

                .btn-dark-red:hover {
                    background: linear-gradient(135deg, #5f1717, #8d2c2c);
                    color: #fff;
                }

                .btn-outline-gold {
                    border: 1px solid var(--gold);
                    color: var(--gold-soft);
                    background: transparent;
                }

                .btn-outline-gold:hover {
                    background: rgba(201, 169, 106, 0.12);
                    color: #fff5dd;
                    border-color: var(--gold-soft);
                }

                .info-panel {
                    background: rgba(11, 10, 15, 0.78);
                    border: 1px solid var(--border);
                    border-radius: 18px;
                    color: var(--text-soft);
                }

                .post-image {
                    height: 240px;
                    object-fit: cover;
                    border-radius: 16px;
                    border: 1px solid rgba(201, 169, 106, 0.18);
                }

                .form-card {
                    max-width: 850px;
                    margin: 0 auto;
                }

                .form-control,
                .form-select,
                textarea {
                    background: rgba(255,255,255,0.06) !important;
                    color: var(--text-main) !important;
                    border: 1px solid rgba(201,169,106,0.24) !important;
                    border-radius: 14px !important;
                }

                .form-control:focus,
                .form-select:focus,
                textarea:focus {
                    box-shadow: 0 0 0 0.2rem rgba(201,169,106,0.18) !important;
                    border-color: var(--gold) !important;
                }

                label, .form-label {
                    color: var(--gold-soft);
                    font-weight: 600;
                }

                .alert {
                    border: none;
                    border-radius: 16px;
                }

                .alert-info {
                    background: rgba(34, 55, 82, 0.85);
                    color: #e8f0ff;
                }

                .alert-success {
                    background: rgba(25, 74, 43, 0.85);
                    color: #effff4;
                }

                .alert-warning {
                    background: rgba(90, 62, 15, 0.88);
                    color: #fff7e6;
                }

                .border-gold {
                    border: 1px solid var(--border);
                }

                .soft-text {
                    color: var(--text-soft);
                }

                .small-meta {
                    color: #d0b98a;
                    font-size: 0.95rem;
                }
            </style>
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg shadow-sm">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">Chroniques du Royaume</a>

                <button class="navbar-toggler btn btn-outline-gold" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('post_list') }}">Chroniques</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('category_list') }}">Maisons</a>
                        </li>

                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('post_new') }}">Nouvelle chronique</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('category_new') }}">Nouvelle maison</a>
                            </li>
                        {% endif %}
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        {% if app.user %}
                            <li class="nav-item">
                                <span class="nav-link">Noble connecté : {{ app.user.email }}</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning" href="{{ path('app_logout') }}">Quitter le royaume</a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-gold" href="{{ path('app_register') }}">Inscription</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <main class="py-5">
            {% block body %}{% endblock %}
        </main>

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
    </body>
</html>