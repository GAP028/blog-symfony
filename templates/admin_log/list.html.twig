{% extends 'base.html.twig' %}

{% block title %}Journal des actions admin{% endblock %}

{% block body %}
    <div class="container">
        <div class="gothic-card p-4">
            <div class="brand-mark">Administration</div>
            <h1 class="section-title mb-2">Journal des actions administrateur</h1>
            <p class="soft-text">Historique des activations, désactivations et suppressions de comptes.</p>

            {% if logs is empty %}
                <div class="alert alert-info mt-4">Aucune action enregistrée.</div>
            {% else %}
                <div class="table-responsive mt-4">
                    <table class="table table-dark table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Action</th>
                                <th>Compte ciblé</th>
                                <th>Effectué par</th>
                                <th>Date</th>
                                <th>Détails</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for log in logs %}
                                <tr>
                                    <td>{{ log.id }}</td>
                                    <td>{{ log.action }}</td>
                                    <td>{{ log.targetEmail }}</td>
                                    <td>{{ log.performedByEmail }}</td>
                                    <td>{{ log.createdAt ? log.createdAt|date('d/m/Y H:i') : '' }}</td>
                                    <td>{{ log.details }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}