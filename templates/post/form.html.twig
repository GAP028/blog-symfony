{% extends 'base.html.twig' %}

{% block title %}Nouvelle chronique{% endblock %}

{% block body %}
    <div class="container">
        <div class="gothic-card p-4 p-md-5 form-card">
            <div class="text-center mb-4">
                <div class="brand-mark">Administration</div>
                <h1 class="section-title mb-2">Rédiger une chronique</h1>
                <p class="soft-text mb-0">
                    Publiez une nouvelle chronique pour enrichir l’histoire du royaume.
                </p>
            </div>

            {{ form_start(form) }}

                <div class="mb-4">
                    {{ form_row(form.title) }}
                </div>

                <div class="mb-4">
                    {{ form_row(form.content) }}
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        {{ form_row(form.publishedAt) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.category) }}
                    </div>
                </div>

                <div class="mt-4">
                    {{ form_row(form.picture) }}
                </div>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <button type="submit" class="btn btn-gold">Enregistrer</button>
                    <a href="{{ path('post_list') }}" class="btn btn-outline-gold">Annuler</a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}