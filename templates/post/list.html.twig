{% extends 'base.html.twig' %}

{% block title %}Liste des articles{% endblock %}

{% block body %}
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="section-title mb-0">Liste des articles</h1>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('post_new') }}" class="btn btn-success">Nouvel article</a>
            {% endif %}
        </div>

        {% if posts is empty %}
            <div class="alert alert-info">Aucun article enregistré.</div>
        {% else %}
            <div class="row g-4">
                {% for post in posts %}
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 p-3">
                            {% if post.picture %}
                                <img
                                    src="{{ post.picture }}"
                                    alt="{{ post.title }}"
                                    class="card-img-top rounded mb-3"
                                    style="height: 220px; object-fit: cover;"
                                >
                            {% endif %}

                            <div class="card-body d-flex flex-column">
                                <h4 class="card-title">{{ post.title }}</h4>

                                <p class="text-muted small mb-2">
                                    {{ post.publishedAt ? post.publishedAt|date('d/m/Y H:i') : 'Date non définie' }}
                                </p>

                                <p class="card-text">
                                    {{ post.content|slice(0, 140) }}{% if post.content|length > 140 %}...{% endif %}
                                </p>

                                <p class="mb-1"><strong>Auteur :</strong> {{ post.author ? post.author.email : 'aucun' }}</p>
                                <p class="mb-3"><strong>Catégorie :</strong> {{ post.category ? post.category.name : 'aucune' }}</p>

                                <div class="mt-auto">
                                    <a href="{{ path('post_show', {'id': post.id}) }}" class="btn btn-primary btn-sm">Voir</a>

                                    {% if is_granted('ROLE_ADMIN') %}
                                        <a href="{{ path('post_edit', {'id': post.id}) }}" class="btn btn-warning btn-sm">Modifier</a>

                                        <form method="post" action="{{ path('post_delete', {'id': post.id}) }}" class="d-inline-block" onsubmit="return confirm('Voulez-vous vraiment supprimer cet article ?');">
                                            <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}