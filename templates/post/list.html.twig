{% extends 'base.html.twig' %}

{% block title %}Chroniques du Royaume{% endblock %}

{% block body %}
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="section-title mb-0">Chroniques du Royaume</h1>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('post_new') }}" class="btn btn-gold">Nouvelle chronique</a>
            {% endif %}
        </div>

        {% if posts is empty %}
            <div class="alert alert-info">Aucune chronique n’a encore été consignée.</div>
        {% else %}
            <div class="row g-4">
                {% for post in posts %}
                    <div class="col-md-6 col-xl-4">
                        <div class="gothic-card p-3 h-100">
                            {% if post.picture %}
                                <img src="{{ asset('uploads/posts/' ~ post.picture) }}" alt="{{ post.title }}" class="img-fluid post-image mb-3">
                            {% endif %}

                            <div class="card-body d-flex flex-column px-1">
                                <h4 class="card-title text-gold">{{ post.title }}</h4>

                                <p class="small-meta mb-2">
                                    {{ post.publishedAt ? post.publishedAt|date('d/m/Y H:i') : 'Date inconnue' }}
                                </p>

                                <p class="soft-text">
                                    {{ post.content|slice(0, 140) }}{% if post.content|length > 140 %}...{% endif %}
                                </p>

                                <p class="mb-1"><strong>Auteur :</strong> {{ post.author ? post.author.email : 'Inconnu' }}</p>
                                <p class="mb-3"><strong>Maison :</strong> {{ post.category ? post.category.name : 'Aucune' }}</p>

                                <div class="mt-auto">
                                    <a href="{{ path('post_show', {'id': post.id}) }}" class="btn btn-outline-gold btn-sm">Lire</a>

                                    {% if is_granted('ROLE_ADMIN') %}
                                        <a href="{{ path('post_edit', {'id': post.id}) }}" class="btn btn-gold btn-sm">Modifier</a>

                                        <form method="post" action="{{ path('post_delete', {'id': post.id}) }}" class="d-inline-block" onsubmit="return confirm('Voulez-vous vraiment effacer cette chronique ?');">
                                            <button type="submit" class="btn btn-dark-red btn-sm">Supprimer</button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}