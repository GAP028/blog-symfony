{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
    <div class="container">
        <div class="gothic-card p-4 mb-4">
            <h1 class="mb-3 text-gold">{{ post.title }}</h1>

            <p class="meta-text">
                Publié le {{ post.publishedAt ? post.publishedAt|date('d/m/Y H:i') : 'date inconnue' }}
            </p>

            <p><strong>Auteur :</strong> {{ post.author ? post.author.email : 'Inconnu' }}</p>
            <p><strong>Maison :</strong> {{ post.category ? post.category.name : 'Aucune' }}</p>

            {% if post.picture %}
                <div class="mb-4">
                    <img src="{{ asset('uploads/posts/' ~ post.picture) }}" alt="{{ post.title }}" class="img-fluid post-image w-100" style="height: 420px;">
                </div>
            {% endif %}

            <hr class="border-gold">

            <div class="soft-text fs-5">
                {{ post.content }}
            </div>

            {% if is_granted('ROLE_ADMIN') %}
                <div class="mt-4">
                    <a href="{{ path('post_edit', {'id': post.id}) }}" class="btn btn-gold">Modifier</a>

                    <form method="post" action="{{ path('post_delete', {'id': post.id}) }}" class="d-inline-block" onsubmit="return confirm('Voulez-vous vraiment effacer cette chronique ?');">
                        <button type="submit" class="btn btn-dark-red">Supprimer</button>
                    </form>
                </div>
            {% endif %}
        </div>

        <div class="gothic-card p-4 mb-4">
            <h2 class="section-title">Paroles de la Cour</h2>

            {% if post.comments is empty %}
                <div class="alert alert-info">Le silence règne encore sur cette chronique.</div>
            {% else %}
                {% set hasValidatedComments = false %}

                {% for comment in post.comments %}
                    {% if comment.status == 'validé' %}
                        {% set hasValidatedComments = true %}

                        <div class="info-panel p-3 mb-3">
                            <p class="mb-2">{{ comment.content }}</p>
                            <small class="meta-text">
                                Par {{ comment.author ? comment.author.email : 'inconnu' }}
                                le {{ comment.createdAt ? comment.createdAt|date('d/m/Y H:i') : '' }}
                            </small>
                        </div>
                    {% endif %}
                {% endfor %}

                {% if not hasValidatedComments %}
                    <div class="alert alert-info">Aucun commentaire validé pour le moment.</div>
                {% endif %}
            {% endif %}
        </div>

        <div class="gothic-card p-4">
            {% if app.user %}
                <h3 class="section-title">Laisser une parole</h3>

                {{ form_start(commentForm, {
                    'action': path('comment_new', {'id': post.id})
                }) }}
                    {{ form_widget(commentForm) }}
                    <button type="submit" class="btn btn-gold mt-3">Commenter</button>
                {{ form_end(commentForm) }}
            {% else %}
                <div class="alert alert-info">
                    Vous devez être connecté pour prendre la parole.
                </div>
            {% endif %}
        </div>

        <a href="{{ path('post_list') }}" class="btn btn-outline-gold mt-4">Retour aux chroniques</a>
    </div>
{% endblock %}