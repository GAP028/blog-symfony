{% extends 'base.html.twig' %}

{% block title %}Inscription au Royaume{% endblock %}

{% block body %}
    <div class="container">
        <div class="gothic-card p-4 form-card">
            <div class="text-center mb-4">
                <div class="brand-mark">Créer un compte</div>
                <h1 class="section-title mb-2">Rejoindre le Royaume</h1>
                <p class="soft-text mb-0">
                    Créez votre compte pour commenter les chroniques et accéder aux espaces réservés.
                </p>
            </div>

            {{ form_start(registrationForm) }}

                <div class="row g-3">
                    <div class="col-md-6">
                        {{ form_row(registrationForm.firstName) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(registrationForm.lastName) }}
                    </div>
                </div>

                <div class="mt-3">
                    {{ form_row(registrationForm.email) }}
                </div>

                <div class="mt-3">
                    {{ form_row(registrationForm.profilePicture) }}
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        {{ form_row(registrationForm.plainPassword.first) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(registrationForm.plainPassword.second) }}
                    </div>
                </div>

                <div class="mt-3">
                    {{ form_row(registrationForm.agreeTerms) }}
                </div>

                <div class="mt-4 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-gold">S’inscrire</button>
                    <a href="{{ path('app_login') }}" class="btn btn-outline-gold">Déjà inscrit ? Se connecter</a>
                </div>

            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}