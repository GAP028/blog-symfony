{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
    <div class="container">
        <div class="gothic-card p-4 p-md-5 form-card">
            <div class="text-center mb-5">
                <div class="brand-mark">Créer un compte</div>
                <h1 class="section-title mb-3">Rejoindre le Royaume</h1>
                <p class="soft-text mb-0">
                    Créez votre compte pour commenter les chroniques et accéder aux espaces réservés.
                </p>
            </div>

            {{ form_start(registrationForm) }}

                <div class="row g-4">
                    <div class="col-md-6">
                        {{ form_row(registrationForm.firstName) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(registrationForm.lastName) }}
                    </div>
                </div>

                <div class="mt-4">
                    {{ form_row(registrationForm.email) }}
                </div>

                <div class="gothic-card p-4 mt-4">
                    <h3 class="section-title mb-3">Photo de profil</h3>
                    <p class="soft-text mb-4">
                        Vous pouvez soit coller un lien d’image, soit téléverser un fichier depuis votre ordinateur.
                    </p>

                    <div class="mb-4">
                        {{ form_row(registrationForm.profilePicture) }}
                    </div>

                    <div>
                        {{ form_row(registrationForm.profilePictureFile) }}
                    </div>
                </div>

                <div class="row g-4 mt-1">
                    <div class="col-md-6">
                        {{ form_row(registrationForm.plainPassword.first) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(registrationForm.plainPassword.second) }}
                    </div>
                </div>

                <div class="mt-4">
                    <div class="form-check">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'class': 'form-check-label ms-2'}}) }}
                        {{ form_errors(registrationForm.agreeTerms) }}
                    </div>
                </div>

                <div class="d-flex gap-3 flex-wrap mt-5">
                    <button type="submit" class="btn btn-gold">S’inscrire</button>
                    <a href="{{ path('app_login') }}" class="btn btn-outline-gold">Déjà inscrit ? Se connecter</a>
                </div>

            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}