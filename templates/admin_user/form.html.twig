{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle }}{% endblock %}

{% block body %}
    <div class="container">
        <div class="gothic-card p-4 p-md-5 form-card">
            <div class="text-center mb-4">
                <div class="brand-mark">Administration</div>
                <h1 class="section-title mb-2">{{ pageTitle }}</h1>
                <p class="soft-text mb-0">
                    Gérez les membres du royaume et leurs permissions.
                </p>
            </div>

            {{ form_start(form) }}

                <div class="row g-4">
                    <div class="col-md-6">
                        {{ form_row(form.firstName) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.lastName) }}
                    </div>
                </div>

                <div class="mt-4">
                    {{ form_row(form.email) }}
                </div>

                <div class="mt-4">
                    {{ form_row(form.profilePicture) }}
                </div>

                <div class="row g-4 mt-1">
                    <div class="col-md-6">
                        {{ form_row(form.role) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.isActive) }}
                    </div>
                </div>

                <div class="row g-4 mt-1">
                    <div class="col-md-6">
                        {{ form_row(form.plainPassword.first) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.plainPassword.second) }}
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <button type="submit" class="btn btn-gold">Enregistrer</button>
                    <a href="{{ path('admin_user_list') }}" class="btn btn-outline-gold">Retour</a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}