{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}
    <div class="container">
        <div class="gothic-card p-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <div class="brand-mark">Administration</div>
                    <h1 class="section-title mb-1">Gestion des utilisateurs</h1>
                    <p class="soft-text mb-0">Consultez, ajoutez, modifiez, activez ou supprimez les comptes.</p>
                </div>

                <a href="{{ path('admin_user_new') }}" class="btn btn-gold">Ajouter un utilisateur</a>
            </div>

            {% if users is empty %}
                <div class="alert alert-info mt-4">Aucun utilisateur enregistré.</div>
            {% else %}
                <div class="table-responsive mt-4">
                    <table class="table table-dark table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Photo</th>
                                <th>ID</th>
                                <th>Email</th>
                                <th>Nom</th>
                                <th>Rôles</th>
                                <th>Statut</th>
                                <th>Date création</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in users %}
                                <tr>
                                    <td>
                                        {% if user.profilePicture %}
                                            <img src="{{ user.profilePicture }}" alt="Photo de profil" class="user-avatar">
                                        {% else %}
                                            <img src="https://via.placeholder.com/80x80?text=User" alt="Photo de profil" class="user-avatar">
                                        {% endif %}
                                    </td>
                                    <td>{{ user.id }}</td>
                                    <td>{{ user.email }}</td>
                                    <td>{{ user.firstName }} {{ user.lastName }}</td>
                                    <td>{{ user.roles|join(', ') }}</td>
                                    <td>
                                        {% if user.isActive %}
                                            <span class="badge bg-success">Actif</span>
                                        {% else %}
                                            <span class="badge bg-danger">Désactivé</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : '' }}</td>
                                    <td class="d-flex gap-1 flex-wrap">
                                        <a href="{{ path('admin_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-gold">Modifier</a>

                                        <a href="{{ path('admin_user_toggle', {'id': user.id}) }}"
                                           class="btn btn-sm {% if user.isActive %}btn-dark-red{% else %}btn-outline-gold{% endif %}">
                                            {% if user.isActive %}Désactiver{% else %}Activer{% endif %}
                                        </a>

                                        <form method="post" action="{{ path('admin_user_delete', {'id': user.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cet utilisateur ?');">
                                            <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}