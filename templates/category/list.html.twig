{% extends 'base.html.twig' %}

{% block title %}Maisons du Royaume{% endblock %}

{% block body %}
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="section-title mb-0">Les Grandes Maisons</h1>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('category_new') }}" class="btn btn-dark-red">Nouvelle maison</a>
            {% endif %}
        </div>

        {% if categories is empty %}
            <div class="alert alert-info">Aucune maison n’a été fondée.</div>
        {% else %}
            <div class="row g-4">
                {% for category in categories %}
                    <div class="col-md-6 col-xl-4">
                        <div class="gothic-card p-4 h-100">
                            <h4 class="text-gold">{{ category.name }}</h4>
                            <p class="soft-text mb-3">
                                {{ category.description ?: 'Aucune chronique n’évoque encore cette maison.' }}
                            </p>

                            {% if is_granted('ROLE_ADMIN') %}
                                <div class="d-flex gap-2 flex-wrap mt-3">
                                    <a href="{{ path('category_edit', {'id': category.id}) }}" class="btn btn-gold btn-sm">
                                        Modifier
                                    </a>

                                    <form method="post" action="{{ path('category_delete', {'id': category.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cette catégorie ?');">
                                        <button type="submit" class="btn btn-dark-red btn-sm">Supprimer</button>
                                    </form>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}