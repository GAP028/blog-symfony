{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle }}{% endblock %}

{% block body %}
    <div class="container">
        <div class="gothic-card p-4 p-md-5 form-card">
            <div class="text-center mb-4">
                <div class="brand-mark">Administration</div>
                <h1 class="section-title mb-2">{{ pageTitle }}</h1>
                <p class="soft-text mb-0">
                    Gérez les maisons et catégories qui structurent le royaume.
                </p>
            </div>

            {{ form_start(form) }}

                <div class="mb-4">
                    {{ form_row(form.name) }}
                </div>

                <div class="mb-4">
                    {{ form_row(form.description) }}
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-dark-red">Enregistrer</button>
                    <a href="{{ path('category_list') }}" class="btn btn-outline-gold">Retour</a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}